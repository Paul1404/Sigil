# ── Sigil Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in the values before running:
#   docker compose up -d

# ── PostgreSQL ───────────────────────────────────────────────────────
# Password for the bundled PostgreSQL container (used by both services)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── Sigil App ────────────────────────────────────────────────────────
# Fernet key for encrypting stored IMAP passwords
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Dashboard login password
ADMIN_PASSWORD=your-admin-password-here

# JWT signing key (random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=generate-a-random-secret-key

# Hours between automatic IMAP fetches (default: 6)
FETCH_INTERVAL_HOURS=6

# ── Optional ─────────────────────────────────────────────────────────
# Host port to expose Sigil on (default: 8000)
# SIGIL_PORT=8000

# Allowed CORS origins (comma-separated, leave empty for same-origin only)
# CORS_ORIGINS=https://sigil.example.com

# Override DATABASE_URL only if using an external database instead of
# the bundled PostgreSQL container:
# DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/sigil
